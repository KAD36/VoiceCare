# ==============================================
# VoiceCare Application - Environment Variables
# ==============================================
# Copy this file to .env and update with your values

# ==============================================
# Node.js Backend Configuration
# ==============================================
NODE_ENV=development
PORT=3000
DATABASE_PATH=./data/voicecare.db

# API Keys (if needed)
# SMS_API_KEY=your_sms_api_key_here
# EMAIL_API_KEY=your_email_api_key_here

# ==============================================
# Django Backend Configuration
# ==============================================
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# Database (SQLite for development, PostgreSQL for production)
# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/voicecare

# Face Recognition Settings
FACE_RECOGNITION_TOLERANCE=0.6
FACE_ENCODING_MODEL=large

# ==============================================
# Mobile App Configuration (config.js)
# ==============================================
# Update these in mobile_app/services/config.js
# FACE_RECOGNITION_URL=http://localhost:8000/api
# APPOINTMENTS_API_URL=http://localhost:3000/api

# ==============================================
# Production Settings (when deploying)
# ==============================================
# DJANGO_DEBUG=False
# NODE_ENV=production
# DATABASE_URL=postgresql://user:password@prod-db:5432/voicecare
# ALLOWED_HOSTS=voicecare.hospital.sa
# CORS_ALLOWED_ORIGINS=https://voicecare.hospital.sa
